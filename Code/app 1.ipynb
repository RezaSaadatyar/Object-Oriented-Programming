    "class human:\n",
    "    def __init__(self, name, lname, age):\n",
    "        self.name = name \n",
    "        self.lname = lname\n",
    "        self.age = age\n",
    "    def fun(self):\n",
    "        return f\"{self.name}\"\n",
    "\n",
    "a = human(name=\"ali\", lname=\"kf\",age=20)\n",
    "print(a.lname)\n",
    "print(a.fun())"
   ]
  }
